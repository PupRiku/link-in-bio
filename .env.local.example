# Supabase project URL (e.g. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Low-privilege client key (anon or publishable). Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Full-access server key (service-role or secret). SERVER ONLY — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Admin email address that is associated with the GitHub OAuth app.
ADMIN_EMAILS=

# Public site origin (e.g. https://riku.example). Used as a fallback when an
# absolute URL is needed server-side (QR target, OAuth) and request headers
# aren't available. Request/forwarded headers take precedence when present.
NEXT_PUBLIC_SITE_URL=